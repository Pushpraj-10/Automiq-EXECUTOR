NODE_ENV=development
EXECUTOR_PORT=4001

# Mongo
MONGODB_URI=mongodb://localhost:27017/automiq

# gRPC
EXECUTOR_GRPC_BIND=0.0.0.0:50051
BACKEND_GRPC_ADDRESS=127.0.0.1:50052
EXECUTOR_SHARED_SECRET=executor-dev-secret
EXECUTOR_GRPC_TLS_ENABLED=false
EXECUTOR_GRPC_MTLS_ENABLED=false
EXECUTOR_GRPC_SERVER_CERT_PATH=
EXECUTOR_GRPC_SERVER_KEY_PATH=
EXECUTOR_GRPC_CA_CERT_PATH=
BACKEND_GRPC_TLS_ENABLED=false
BACKEND_GRPC_CA_CERT_PATH=
BACKEND_GRPC_CLIENT_CERT_PATH=
BACKEND_GRPC_CLIENT_KEY_PATH=
BACKEND_GRPC_RETRY_ATTEMPTS=3
BACKEND_GRPC_RETRY_BASE_MS=200
BACKEND_GRPC_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
BACKEND_GRPC_CIRCUIT_BREAKER_RESET_MS=10000

# Email (optional)
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_DEFAULT_FROM=

# Worker tuning
WORKER_POLL_INTERVAL_MS=3000
WORKER_BATCH_SIZE=5
QUEUE_LOCK_TIMEOUT_MS=60000
