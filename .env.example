NODE_ENV=development
EXECUTOR_PORT=4001

# Mongo
MONGODB_URI=mongodb://localhost:27017/automiq

# gRPC
EXECUTOR_GRPC_BIND=0.0.0.0:50051
BACKEND_GRPC_ADDRESS=127.0.0.1:50052
EXECUTOR_SHARED_SECRET=executor-dev-secret

# Email (optional)
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_DEFAULT_FROM=

# Worker tuning
WORKER_POLL_INTERVAL_MS=3000
WORKER_BATCH_SIZE=5
QUEUE_LOCK_TIMEOUT_MS=60000
